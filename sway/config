# --- rice spring de sway :3 ---
# dedicado a mi hermosa, preciosa, bella y asombrosa espoza :333

# Variables de Color
set $spring_bg        #2A4B42
set $spring_bg_alt    #4B7F72
set $spring_fg        #F2EB91
set $spring_fg_dark   #282828
set $spring_border    #504945
set $spring_urgent    #BF616A

# Fuentes
font pango:Ubuntu Nerd Font 10

# Tecla MOD (Super/Windows)
set $mod Mod4

# Direcciones
set $left h
set $down j
set $up k
set $right l

# --- ESTILO DE VENTANAS (Limpio y sin títulos) ---

# Eliminar las barras de título de todas las ventanas
default_border pixel 1
default_floating_border pixel 1

# Colores de los bordes (Esquema Spring)
# Sintaxis: <clase> <borde> <fondo> <texto> <indicador> <borde_hijo>

# Ventana Enfocada (Amarillo Crema)
client.focused          #F2EB91 #F2EB91 #282828 #F2EB91 #F2EB91

# Ventana Inactiva (Verde Musgo)
client.focused_inactive #4B7F72 #4B7F72 #F2EB91 #4B7F72 #4B7F72

# Ventana de fondo (Verde Bosque)
client.unfocused        #2A4B42 #2A4B42 #F2EB91 #2A4B42 #2A4B42

# Ventana Urgente (Rojo suave/Naranja)
client.urgent           #BF616A #BF616A #FFFFFF #BF616A #BF616A

# Nota: Al usar 'border pixel', el color de <fondo> y <texto> no se verá 
# porque ya no hay barra de título, pero deben estar ahí para evitar errores.

# Grosor de borde y huecos (Gaps)
gaps inner 4
gaps outer 4

# --- Lanzador (Rofi) ---
bindsym $mod+d exec rofi -show drun

# --- Terminal ---
set $term foot
bindsym $mod+Return exec $term

# --- Waybar (Barra) ---
bar {
    swaybar_command waybar
}

# --- Fondo de Pantalla ---
# Usa un fondo de color sólido o una imagen
# output * bg #2A4B42 solid
output * bg /home/uwusamaa/Descargas/wp8190159-green-yellow-wallpapers.jpg fill

# --- CONTROL DE MOUSE ---

# Mantén presionado $mod y el botón izquierdo para arrastrar una ventana (la vuelve flotante)
floating_modifier $mod

# Acciones con botones del mouse sobre el título de la ventana
# Botón izquierdo: enfocar | Botón derecho: volver flotante | Botón central: cerrar
bindsym --whole-window $mod+button2 floating toggle
bindsym --whole-window $mod+button3 kill

# Scroll en la barra de título para cambiar entre ventanas (en modo tabbed/stacking)
bindsym --whole-window $mod+button4 focus left
bindsym --whole-window $mod+button5 focus right

# Cerrar ventana activa
bindsym $mod+q kill

# Cambiar foco (Flechas o Vim keys)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Mover ventana activa
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Mover el foco al contenedor "padre" (selecciona todo el grupo)
bindsym $mod+a focus parent

# Mover el foco al contenedor "hijo" 
bindsym $mod+z focus child

# Dividir horizontalmente / verticalmente
bindsym $mod+v splitv

# Alternar estilos de disposición
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Pantalla completa
bindsym $mod+f fullscreen toggle

# Alternar entre flotante y tiling
bindsym $mod+Shift+space floating toggle

# Cambiar foco entre ventanas flotantes y tiling
bindsym $mod+space focus mode_toggle

# Mover ventana al "Scratchpad" (una zona invisible para ocultar apps como Spotify o la terminal)
bindsym $mod+Shift+minus move scratchpad
# Mostrar/ciclar ventanas del Scratchpad
bindsym $mod+minus scratchpad show

# Cambiar de workspace
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Mover contenedor al workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
# ... (repite hasta el 0 si lo necesitas)

# Recargar configuración (aplica cambios de colores/waybar al instante)
bindsym $mod+Shift+c reload

# Salir de Sway (Logout)
bindsym $mod+Shift+e exec swaynag -t warning -m '¿Deseas salir?' -b 'Sí' 'swaymsg exit'
